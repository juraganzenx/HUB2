--// COLLECT DROPPED ITEMS V4 + TARGET PLAYER CHECK

local Players = game:GetService("Players")
local TweenService = game:GetService("TweenService")

local LocalPlayer = Players.LocalPlayer

--------------------------------------------------
-- ANTI AFK
--------------------------------------------------

local VirtualUser = game:GetService("VirtualUser")


LocalPlayer.Idled:Connect(function()
    pcall(function()
        VirtualUser:CaptureController()

        local Camera = workspace.CurrentCamera

        VirtualUser:Button2Down(
            Vector2.new(0, 0),
            Camera.CFrame
        )

        task.wait(1)

        VirtualUser:Button2Up(
            Vector2.new(0, 0),
            Camera.CFrame
        )

        print("Anti AFK")
    end)
end)

local DropFolder = workspace:WaitForChild("DroppedItems")

--------------------------------------------------
-- CONFIG
--------------------------------------------------

local SPEED = 30
local CHECK_DELAY = 2
local MAX_SHECKLES = 100000000000

local TARGET_PLAYER = "otmoonbloom1"
local MIN_DISTANCE = 20

--------------------------------------------------
-- VARIABLES
--------------------------------------------------

local Busy = false
local Processing = {}

--------------------------------------------------
-- FUNCTIONS
--------------------------------------------------

local function GetSheckles()
	local leaderstats = LocalPlayer:FindFirstChild("leaderstats")

	if not leaderstats then
		return 0
	end

	local sheckles = leaderstats:FindFirstChild("Sheckles")

	if not sheckles or not sheckles:IsA("IntValue") then
		return 0
	end

	return sheckles.Value
end


--------------------------------------------------
-- TWEEN
--------------------------------------------------

local function TweenTo(cf)

	local Character = LocalPlayer.Character 
		or LocalPlayer.CharacterAdded:Wait()

	local HumanoidRootPart = Character:WaitForChild("HumanoidRootPart")


	local distance = (HumanoidRootPart.Position - cf.Position).Magnitude

	if distance <= 2 then
		return
	end


	local time = distance / SPEED


	local Tween = TweenService:Create(
		HumanoidRootPart,
		TweenInfo.new(
			time,
			Enum.EasingStyle.Linear
		),
		{
			CFrame = cf
		}
	)


	Tween:Play()
	Tween.Completed:Wait()

end


--------------------------------------------------
-- CHECK TARGET PLAYER
--------------------------------------------------

local function CheckTargetPlayer()

	local Target = Players:FindFirstChild(TARGET_PLAYER)

	if not Target then
		return
	end


	local TargetChar = Target.Character

	if not TargetChar then
		return
	end


	local TargetHRP = TargetChar:FindFirstChild("HumanoidRootPart")

	if not TargetHRP then
		return
	end



	local Character = LocalPlayer.Character 
		or LocalPlayer.CharacterAdded:Wait()

	local MyHRP = Character:WaitForChild("HumanoidRootPart")


	local Distance = (
		MyHRP.Position - TargetHRP.Position
	).Magnitude



	if Distance > MIN_DISTANCE then

		print(
			"Tween ke",
			TARGET_PLAYER,
			"Distance:",
			math.floor(Distance)
		)


		TweenTo(
			TargetHRP.CFrame 
			* CFrame.new(0,3,0)
		)

	end

end



--------------------------------------------------
-- FIND DROP ITEM
--------------------------------------------------

local function GetNextItem()

	for _, Model in ipairs(DropFolder:GetChildren()) do

		if Model:IsA("Model") 
			and not Processing[Model] then


			local Anchor = Model:FindFirstChild("PromptAnchor")


			if Anchor 
				and Anchor:IsA("BasePart") then


				local Prompt = Anchor:FindFirstChild("PickupPrompt")


				if Prompt 
					and Prompt:IsA("ProximityPrompt") then


					return Model

				end
			end
		end
	end


	return nil

end



--------------------------------------------------
-- COLLECT ITEM
--------------------------------------------------

local function CollectItem(Model)

	if not Model 
		or not Model.Parent then
		return
	end


	Processing[Model] = true



	local Anchor = Model:FindFirstChild("PromptAnchor")

	local Prompt = Anchor 
		and Anchor:FindFirstChild("PickupPrompt")



	if not Anchor 
		or not Prompt then

		Processing[Model] = nil
		return

	end



	-- Pergi ke drop
	TweenTo(
		Anchor.CFrame 
		* CFrame.new(0,3,0)
	)



	while Model.Parent 
		and Prompt.Parent do


		if GetSheckles() > MAX_SHECKLES then
			break
		end



		pcall(function()

			fireproximityprompt(Prompt)

		end)



		task.wait(0.05)

	end



	Processing[Model] = nil

end



--------------------------------------------------
-- MAIN LOOP
--------------------------------------------------

local function CollectLoop()


	if Busy then
		return
	end



	if GetSheckles() > MAX_SHECKLES then
		return
	end



	Busy = true



	-- CHECK PLAYER DULU
	CheckTargetPlayer()



	while true do


		if GetSheckles() > MAX_SHECKLES then
			break
		end



		local Model = GetNextItem()



		if not Model then
			break
		end



		CollectItem(Model)



	end



	Busy = false

end



--------------------------------------------------
-- AUTO COLLECT
--------------------------------------------------

task.spawn(function()

	while true do

		pcall(function()

			CollectLoop()

		end)


		task.wait(CHECK_DELAY)

	end

end)
