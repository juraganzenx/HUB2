local Players = game:GetService("Players")
local TweenService = game:GetService("TweenService")

local LocalPlayer = Players.LocalPlayer

local Map = workspace:WaitForChild("Map")
local SeedPackSpawn = Map:WaitForChild("SeedPackSpawnServerLocations")

local SPEED = 40 -- studs per detik

local function TweenTo(cf)
    local Character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    local HumanoidRootPart = Character:WaitForChild("HumanoidRootPart")

    local distance = (HumanoidRootPart.Position - cf.Position).Magnitude
    local time = distance / SPEED

    local tween = TweenService:Create(
        HumanoidRootPart,
        TweenInfo.new(time, Enum.EasingStyle.Linear),
        {
            CFrame = cf
        }
    )

    tween:Play()
    tween.Completed:Wait()
end

local function CollectSeedPack()
    local Part = SeedPackSpawn:FindFirstChild("Part")
    if not Part then
        return
    end

    -- Tween ke atas Part
    TweenTo(Part.CFrame + Vector3.new(0, 3, 0))

    -- Spam ProximityPrompt
    local Prompt = Part:FindFirstChild("ProximityPrompt")
    if Prompt then
        while Part.Parent and Prompt.Parent do
            pcall(function()
                fireproximityprompt(Prompt)
            end)
            task.wait(0.05)
        end
    end
end

-- Saat ada Seed Pack baru muncul
SeedPackSpawn.ChildAdded:Connect(function()
    task.wait(0.1)
    CollectSeedPack()
end)
