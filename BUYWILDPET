--------------------------------------------------
-- SETTINGS
--------------------------------------------------

local CHECK_DELAY = 2

local WHITELIST = {
    ["Raccoon"] = true,
    ["Unicorn"] = true,
    ["GoldeDragonfly"] = true,
    ["Dragonfly"] = true,
    ["BlackDragon"] = true,
    ["IceSerpent"] = true,
}

-- Ganti dengan Discord Webhook kamu
local DISCORD_WEBHOOK = "https://discord.com/api/webhooks/1476987739898515571/46Ws80ynwg5pYRC_ioOxxiYwwsS4odCDEySKSdZ8r4DNSsdrQPzTmjh49Tomq_1Wt1kO"

--------------------------------------------------
-- SERVICES
--------------------------------------------------

local Players = game:GetService("Players")
local HttpService = game:GetService("HttpService")

local LocalPlayer = Players.LocalPlayer

local function GetRoot()
    local Character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    return Character:WaitForChild("HumanoidRootPart")
end

--------------------------------------------------
-- PATH
--------------------------------------------------

local WildPetSpawns = workspace
    :WaitForChild("Map")
    :WaitForChild("WildPetSpawns")

--------------------------------------------------
-- DISCORD NOTIFICATION
--------------------------------------------------

local req =
    (syn and syn.request)
    or request
    or http_request
    or (http and http.request)
    or (fluxus and fluxus.request)

local Seen = {}

local function SendDiscordNotification(petName)
    if not req or DISCORD_WEBHOOK == "" then
        return
    end

    pcall(function()
        req({
            Url = DISCORD_WEBHOOK,
            Method = "POST",
            Headers = {
                ["Content-Type"] = "application/json"
            },
            Body = HttpService:JSONEncode({
                username = "Wild Pet Notifier",
                embeds = {{
                    title = "🐾 Wild Pet Spawned",
                    description = "**Pet:** `" .. petName .. "`",
                    color = 16776960,
                    timestamp = DateTime.now():ToIsoDate(),
                }}
            })
        })
    end)
end

--------------------------------------------------
-- SEND NOTIFICATION WHEN PET SPAWNS
--------------------------------------------------

WildPetSpawns.ChildAdded:Connect(function(pet)
    task.wait(0.1)

    local petName = pet:GetAttribute("PetName")

    if petName and WHITELIST[petName] and not Seen[pet] then
        Seen[pet] = true

        print("[NOTIFY] " .. petName)
        SendDiscordNotification(petName)
    end
end)

WildPetSpawns.ChildRemoved:Connect(function(pet)
    Seen[pet] = nil
end)

--------------------------------------------------
-- AUTO BUY LOOP
--------------------------------------------------

while task.wait(CHECK_DELAY) do
    for _, pet in ipairs(WildPetSpawns:GetChildren()) do
        local petName = pet:GetAttribute("PetName")

        if petName and WHITELIST[petName] then
            local root = pet:FindFirstChild("RootPart")

            if root then
                local prompt = root:FindFirstChild("BuyPrompt")

                if prompt and prompt:IsA("ProximityPrompt") then
                    local hrp = GetRoot()

                    -- Simpan posisi awal
                    local oldCFrame = hrp.CFrame

                    -- Teleport ke pet
                    hrp.CFrame = root.CFrame + Vector3.new(0, 0, 3)
                    task.wait(0.2)

                    -- Buy
                    pcall(function()
                        fireproximityprompt(prompt)
                    end)

                    print("[AUTO BUY] " .. petName)

                    task.wait(0.3)

                    -- Kembali ke posisi semula
                    hrp.CFrame = oldCFrame

                    task.wait(0.2)
                end
            end
        end
    end
end
