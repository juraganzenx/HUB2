--/TELE KEGARDEN
local Players = game:GetService("Players")

--// Player
local LocalPlayer = Players.LocalPlayer
local Character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
local HumanoidRootPart = Character:WaitForChild("HumanoidRootPart")

--// Gardens
local Gardens = workspace:WaitForChild("Gardens")

--// Cari plot milik kita
local function GetMyPlot()
    for i = 1, 8 do
        local Plot = Gardens:FindFirstChild("Plot" .. i)

        if Plot and Plot:GetAttribute("Owner") == LocalPlayer.Name then
            return Plot
        end
    end
    return nil
end

--// Teleport ke Front_BedSection.BottomFace
local function TeleportToMyPlot()
    local Plot = GetMyPlot()
    if not Plot then
        warn("Plot tidak ditemukan!")
        return
    end

    local targetPart = Plot
        :WaitForChild("Visual")
        :WaitForChild("FRONT_BedSection")
        :WaitForChild("BottomFace")

    if not targetPart then
        warn("BottomFace tidak ditemukan!")
        return
    end

    -- teleport sedikit di atas biar tidak clip
    HumanoidRootPart.CFrame = targetPart.CFrame + Vector3.new(0, 3, 0)
end

while true do
    TeleportToMyPlot()
    task.wait(30)
end
