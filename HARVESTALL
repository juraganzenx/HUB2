local Fruits = Plant:FindFirstChild("Fruits")

if Fruits then
    -- PRIORITAS: Fruit yang punya Mutation
    for _, Fruit in ipairs(Fruits:GetChildren()) do
        if not Fruit:GetAttribute("Mutation") then
            continue
        end

        local CorePartName = Fruit:GetAttribute("CorePartName")

        if BLACKLIST[CorePartName] then
            continue
        end

        local HarvestPart = Fruit:FindFirstChild("HarvestPart")
        local Prompt = HarvestPart and HarvestPart:FindFirstChild("HarvestPrompt")

        if Prompt and Prompt:IsA("ProximityPrompt") then
            pcall(function()
                fireproximityprompt(Prompt)
            end)

            harvested += 1
        end
    end

    -- KEMUDIAN: Fruit yang tidak punya Mutation
    for _, Fruit in ipairs(Fruits:GetChildren()) do
        if Fruit:GetAttribute("Mutation") then
            continue
        end

        local CorePartName = Fruit:GetAttribute("CorePartName")

        if BLACKLIST[CorePartName] then
            continue
        end

        local HarvestPart = Fruit:FindFirstChild("HarvestPart")
        local Prompt = HarvestPart and HarvestPart:FindFirstChild("HarvestPrompt")

        if Prompt and Prompt:IsA("ProximityPrompt") then
            pcall(function()
                fireproximityprompt(Prompt)
            end)

            harvested += 1
        end
    end
end
